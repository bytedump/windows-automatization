# Local credentials and config — NEVER commit
config.ps1
# Backup/copy variants (Windows Explorer PT/EN, editors) — a copy of config.ps1 leaks creds.
# No dot anchor: Explorer's second copy is 'name - Copy (2).ext'; pt-BR Windows writes the
# accented 'Cópia'.
*.bak
* - Copia*
* - Cópia*
* - Copy*

# Internal technical summary (IPs/architecture/internal portals) — repo is PUBLIC, NEVER commit
resumo-windows-auto.md

# Session handoff (internal context + IPs) — stays local, NEVER commit
HANDOFF.md

# "Real rehearsal" harness (points at the real/local USB drive) — stays local, out of the public repo
tests/prep-real.ps1
tests/bootstrap-real.ps1

# Real printers (internal IPs/sectors) — use printers.example.json as the base.
# Root-anchored: the fake fixture tests/usb-sim/printers.json IS versioned on purpose.
/printers.json

# Office ODT — the real configuration.xml may carry a PIDKEY (LTSC); only the example is versioned
configuration.xml

# Real autounattend.xml (generated by build-usb.ps1 with the bootstrap password) — only
# autounattend.template.xml is versioned. NEVER commit the generated one.
autounattend.xml

# Installers and binaries (large, live on the USB drive/network)
*.msi
*.MSI
*.exe
*.EXE
*.zip
*.ZIP
*.rar
*.RAR
*.dll
*.DLL
*.dmg
*.DMG

# Images (wallpapers, drivers) — except the README screenshot
*.jpg
*.jpeg
*.png
!docs/setup-gui.png
*.bmp

# VPN — sensitive configs
*.ovpn

# Documents/spreadsheets
*.xlsx
*.xls
*.pdf

# macOS junk
.DS_Store
._*

# Logs generated during setup
*.log

# Cloud-agent vendor toolkit (binaries + operational scripts, live on the USB drive)
CloudAgent/

# Signatures — employee personal data, operational (only the USB-root tree;
# the test fixture in tests/usb-sim/signatures-2026/ is versioned on purpose)
/signatures-*/
/assinatura-*/

# Windows/macOS junk
*.lnk
*Zone.Identifier
